{
  "printWidth": 100,
  "parser": "typescript",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "overrides": [
    {
      "files": "**/*.md",
      "options": {
        "parser": "markdown"
      }
    },
    {
      "files": "**/*.css",
      "options": {
        "parser": "css"
      }
    },
    {
      "files": ["**/importMap.js", "**/payload-types.ts", "**/**.yaml", "**/**.yml"],
      "options": {
        "requirePragma": true
      }
    }
  ]
}
