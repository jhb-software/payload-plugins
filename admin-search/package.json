{
  "name": "@jhb.software/payload-admin-search",
  "version": "0.2.1",
  "description": "A global search plugin for the Payload CMS admin panel.",
  "keywords": [
    "payload",
    "plugin",
    "search",
    "admin"
  ],
  "author": "JHB Software",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "clean": "rimraf --glob {dist,*.tsbuildinfo}",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev dev",
    "format": "prettier --write src \"*.{json,md,js,mjs,cjs}\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "pnpm clean && pnpm build",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/translations": "^3.83.0"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.83.0",
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@payloadcms/db-mongodb": "^3.83.0",
    "@payloadcms/eslint-config": "^3.28.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/plugin-search": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "next": "16.2.4",
    "payload": "^3.83.0",
    "prettier": "^3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./client": {
        "import": "./dist/exports/client.js",
        "types": "./dist/exports/client.d.ts",
        "default": "./dist/exports/client.js"
      }
    }
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "import": "./src/exports/client.ts",
      "types": "./src/exports/client.ts",
      "default": "./src/exports/client.ts"
    }
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
