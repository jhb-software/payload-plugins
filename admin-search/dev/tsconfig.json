{
  "extends": "../tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build"],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@payload-config": ["./src/payload.config.ts"],
      "payload/generated-types": ["./src/payload-types.ts"],
      "@jhb.software/payload-admin-search": ["../src/index.ts"],
      "@jhb.software/payload-admin-search/client": ["../src/exports/client.ts"]
    },
    "noEmit": true,
    "emitDeclarationOnly": false
  }
}
