{
  "name": "payload-plugins",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:all": "pnpm build:admin-search && pnpm build:alt-text && pnpm build:astro-payload-richtext-lexical && pnpm build:chat-agent && pnpm build:cloudinary && pnpm build:pages && pnpm build:geocoding && pnpm build:content-translator && pnpm build:vercel-deployments",
    "build:chat-agent": "cd ./chat-agent && pnpm build",
    "build:astro-payload-richtext-lexical": "cd ./astro-payload-richtext-lexical && pnpm build",
    "build:admin-search": "cd ./admin-search && pnpm build",
    "build:alt-text": "cd ./alt-text && pnpm build",
    "build:cloudinary": "cd ./cloudinary && pnpm build",
    "build:content-translator": "cd ./content-translator && pnpm build",
    "build:geocoding": "cd ./geocoding && pnpm build",
    "build:pages": "cd ./pages && pnpm build",
    "build:vercel-deployments": "cd ./vercel-deployments && pnpm build",
    "lint:all": "pnpm lint:admin-search && pnpm lint:alt-text && pnpm lint:astro-payload-richtext-lexical && pnpm lint:chat-agent && pnpm lint:cloudinary && pnpm lint:geocoding && pnpm lint:pages && pnpm lint:content-translator && pnpm lint:vercel-deployments",
    "lint:chat-agent": "cd ./chat-agent && pnpm lint",
    "lint:admin-search": "cd ./admin-search && pnpm lint",
    "lint:astro-payload-richtext-lexical": "cd ./astro-payload-richtext-lexical && pnpm lint",
    "lint:alt-text": "cd ./alt-text && pnpm lint",
    "lint:cloudinary": "cd ./cloudinary && pnpm lint",
    "lint:content-translator": "cd ./content-translator && pnpm lint",
    "lint:geocoding": "cd ./geocoding && pnpm lint",
    "lint:pages": "cd ./pages && pnpm lint",
    "lint:vercel-deployments": "cd ./vercel-deployments && pnpm lint",
    "format:all": "pnpm format:admin-search && pnpm format:alt-text && pnpm format:astro-payload-richtext-lexical && pnpm format:chat-agent && pnpm format:cloudinary && pnpm format:geocoding && pnpm format:pages && pnpm format:content-translator && pnpm format:vercel-deployments",
    "format:chat-agent": "cd ./chat-agent && pnpm format",
    "format:astro-payload-richtext-lexical": "cd ./astro-payload-richtext-lexical && pnpm format",
    "format:admin-search": "cd ./admin-search && pnpm format",
    "format:alt-text": "cd ./alt-text && pnpm format",
    "format:cloudinary": "cd ./cloudinary && pnpm format",
    "format:content-translator": "cd ./content-translator && pnpm format",
    "format:geocoding": "cd ./geocoding && pnpm format",
    "format:pages": "cd ./pages && pnpm format",
    "format:vercel-deployments": "cd ./vercel-deployments && pnpm format",
    "install:all": "pnpm install:admin-search && pnpm install:alt-text && pnpm install:astro-payload-richtext-lexical && pnpm install:chat-agent && pnpm install:cloudinary && pnpm install:geocoding && pnpm install:pages && pnpm install:content-translator && pnpm install:vercel-deployments",
    "install:chat-agent": "cd ./chat-agent && pnpm install --frozen-lockfile",
    "install:astro-payload-richtext-lexical": "cd ./astro-payload-richtext-lexical && pnpm install",
    "install:admin-search": "cd ./admin-search && pnpm install --frozen-lockfile",
    "install:alt-text": "cd ./alt-text && pnpm install --frozen-lockfile",
    "install:cloudinary": "cd ./cloudinary && pnpm install --frozen-lockfile",
    "install:content-translator": "cd ./content-translator && pnpm install --frozen-lockfile",
    "install:geocoding": "cd ./geocoding && pnpm install --frozen-lockfile",
    "install:pages": "cd ./pages && pnpm install --frozen-lockfile",
    "install:vercel-deployments": "cd ./vercel-deployments && pnpm install --frozen-lockfile",
    "test:all": "pnpm test:pages",
    "test:pages": "cd ./pages && pnpm test",
    "prepare": "git config core.hooksPath .husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,yaml,yml}": "prettier --write"
  }
}
