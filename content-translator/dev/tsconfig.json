{
  "extends": "../tsconfig.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build"],
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@payload-config": ["./src/payload.config.ts"],
      "payload/generated-types": ["./src/payload-types.ts"],
      "@jhb.software/payload-content-translator-plugin": ["../src/index.ts"],
      "@jhb.software/payload-content-translator-plugin/types": ["../src/types.ts"],
      "@jhb.software/payload-content-translator-plugin/resolvers/types": [
        "../src/resolvers/types.ts"
      ],
      "@jhb.software/payload-content-translator-plugin/resolvers/openAI": [
        "../src/resolvers/openAI.ts"
      ],
      "@jhb.software/payload-content-translator-plugin/client": ["../src/exports/client.ts"]
    },
    "noEmit": true,
    "emitDeclarationOnly": false
  }
}
