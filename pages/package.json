{
  "name": "@jhb.software/payload-pages-plugin",
  "version": "0.7.0",
  "description": "Payload CMS plugin that adds essential fields for hierarchical page structure to collections.",
  "bugs": "https://github.com/jhb-software/payload-plugins/issues",
  "repository": "https://github.com/jhb-software/payload-plugins",
  "keywords": [
    "payload",
    "plugin",
    "pages"
  ],
  "author": "JHB Software",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "clean": "rimraf --glob {dist,*.tsbuildinfo}",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev dev",
    "dev:unlocalized": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev dev_unlocalized",
    "dev:multi-tenant": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev dev_multi_tenant",
    "format": "prettier --write src \"*.{json,md,js,mjs,cjs}\"",
    "test": "pnpm test:localized && pnpm test:unlocalized && pnpm test:multi-tenant",
    "test:localized": "pnpm test:localized:mongodb && pnpm test:localized:sqlite",
    "test:localized:mongodb": "cross-env PAYLOAD_DATABASE=mongodb vitest run --config dev/vite.config.ts",
    "test:localized:sqlite": "cross-env PAYLOAD_DATABASE=sqlite vitest run --config dev/vite.config.ts",
    "test:unlocalized": "pnpm test:unlocalized:mongodb && pnpm test:unlocalized:sqlite",
    "test:unlocalized:mongodb": "cross-env PAYLOAD_DATABASE=mongodb vitest run --config dev_unlocalized/vite.config.ts",
    "test:unlocalized:sqlite": "cross-env PAYLOAD_DATABASE=sqlite vitest run --config dev_unlocalized/vite.config.ts",
    "test:multi-tenant": "pnpm test:multi-tenant:mongodb && pnpm test:multi-tenant:sqlite",
    "test:multi-tenant:mongodb": "cross-env PAYLOAD_DATABASE=mongodb vitest run --config dev_multi_tenant/vite.config.ts",
    "test:multi-tenant:sqlite": "cross-env PAYLOAD_DATABASE=sqlite vitest run --config dev_multi_tenant/vite.config.ts",
    "test:watch": "vitest watch --config dev/vite.config.ts",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.config.ts PAYLOAD_DATABASE=mongodb payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.config.ts payload generate:importmap"
  },
  "dependencies": {
    "qs-esm": "^8.0.1"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.83.0",
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@payloadcms/db-mongodb": "^3.83.0",
    "@payloadcms/db-sqlite": "^3.83.0",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/plugin-multi-tenant": "^3.83.0",
    "@payloadcms/translations": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "copyfiles": "2.4.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "next": "16.2.4",
    "payload": "^3.83.0",
    "prettier": "^3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./client": {
        "import": "./dist/exports/client.js",
        "types": "./dist/exports/client.d.ts",
        "default": "./dist/exports/client.js"
      },
      "./server": {
        "import": "./dist/exports/server.js",
        "types": "./dist/exports/server.d.ts",
        "default": "./dist/exports/server.js"
      }
    }
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "import": "./src/exports/client.ts",
      "types": "./src/exports/client.ts",
      "default": "./src/exports/client.ts"
    },
    "./server": {
      "import": "./src/exports/server.ts",
      "types": "./src/exports/server.ts",
      "default": "./src/exports/server.ts"
    }
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
