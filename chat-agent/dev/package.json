{
  "name": "chat-agent-dev",
  "description": "Dev app for the chat-agent plugin.",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --webpack --port 3940",
    "dev:turbo": "pnpm dev --turbo",
    "dev:safe": "rm -rf .next && pnpm dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts payload generate:importmap"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/react": "^3.0.210",
    "@jhb.software/payload-chat-agent": "workspace:*",
    "@payloadcms/db-mongodb": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "ai": "^6.0.208",
    "next": "16.2.9",
    "payload": "^3.85.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.1.1"
}
