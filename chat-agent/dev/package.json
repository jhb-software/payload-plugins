{
  "name": "chat-agent-dev",
  "description": "Dev app for the chat-agent plugin.",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev --port 3940",
    "dev:turbo": "pnpm dev --turbo",
    "dev:safe": "rm -rf .next && pnpm dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts payload generate:importmap",
    "run:agent": "cross-env PAYLOAD_CONFIG_PATH=./src/payload.config.ts NODE_OPTIONS=\"--no-deprecation\" tsx ./src/scripts/run-agent.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.166",
    "@jhb.software/payload-chat-agent": "workspace:*",
    "@payloadcms/db-mongodb": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "ai": "^6.0.164",
    "next": "15.4.11",
    "payload": "^3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.20.6"
  }
}
