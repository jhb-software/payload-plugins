{
  "name": "@jhb.software/astro-payload-richtext-lexical",
  "version": "0.3.2",
  "description": "Renders Payload CMS Lexical rich text content to Astro elements.",
  "keywords": [
    "payload",
    "astro",
    "lexical",
    "rich text",
    "renderer"
  ],
  "homepage": "https://github.com/jhb-software/payload-plugins",
  "bugs": "https://github.com/jhb-software/payload-plugins/issues",
  "repository": "https://github.com/jhb-software/payload-plugins",
  "license": "MIT",
  "author": "JHB Software",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./RichTextLexical.astro": "./src/RichTextLexical.astro"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "format": "prettier --write src \"*.{json,md,js,mjs,cjs,astro}\"",
    "format:check": "prettier --check src \"*.{json,md,js,mjs,cjs,astro}\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "pnpm run build",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "ts:check": "tsc"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "astro": "^6.1.7",
    "eslint": "^9.18.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "astro": ">=6.x"
  },
  "publishConfig": {},
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
