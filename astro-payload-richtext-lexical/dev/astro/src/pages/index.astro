---
import RichTextLexical from '@jhb.software/astro-payload-richtext-lexical/RichTextLexical.astro'
import CustomBlock from '../components/CustomBlock.astro'
import CustomUpload from '../components/CustomUpload.astro'
import { resolveInternalLink } from '../lib/resolveInternalLink'

// Base URL of the Payload app (see ../../../payload). Override with PAYLOAD_URL.
const payloadUrl = import.meta.env.PAYLOAD_URL ?? 'http://localhost:3000'

type LexicalDocument = {
  id: number | string
  title: string
  content?: { root?: { children?: any[] } }
}

let documents: LexicalDocument[] = []
let error: string | null = null

try {
  const res = await fetch(`${payloadUrl}/api/documents?limit=100&depth=2`)
  if (!res.ok) throw new Error(`Payload responded ${res.status}`)
  documents = (await res.json()).docs ?? []
} catch (e) {
  error = e instanceof Error ? e.message : String(e)
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Live Payload table preview</title>
    <style is:global>
      body {
        font-family: system-ui, sans-serif;
        max-width: 60rem;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      table {
        border-collapse: collapse;
        margin: 1rem 0 2rem;
        width: 100%;
      }
      th,
      td {
        border: 1px solid #ccc;
        padding: 0.4rem 0.6rem;
        text-align: left;
      }
      th {
        background: #f3f3f3;
      }
      .error {
        background: #fff4f4;
        border: 1px solid #e0b4b4;
        padding: 1rem;
        border-radius: 0.5rem;
      }
    </style>
  </head>
  <body>
    <h1>Live Payload table preview</h1>
    <p>
      Rendering documents fetched live from the Payload app at <code>{payloadUrl}</code>. Edit a
      document's tables in the <a href={`${payloadUrl}/admin`}>Payload admin</a> and reload this
      page to see the renderer's output.
    </p>

    {
      error && (
        <div class="error">
          <strong>Could not reach Payload:</strong> {error}.<br />
          Start the Payload app with <code>pnpm --filter
          astro-payload-richtext-lexical-payload-app dev</code> (runs on port 3000).
        </div>
      )
    }

    {
      documents.map((doc) => (
        <section>
          <h2>{doc.title}</h2>
          {doc.content?.root?.children ? (
            <RichTextLexical
              nodes={doc.content.root.children}
              BlockRenderer={CustomBlock}
              UploadRenderer={CustomUpload}
              resolveInternalLink={resolveInternalLink}
            />
          ) : (
            <p>
              <em>No content.</em>
            </p>
          )}
        </section>
      ))
    }
  </body>
</html>
