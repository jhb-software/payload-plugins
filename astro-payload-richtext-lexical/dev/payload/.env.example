# Copy to .env and adjust. All values have dev fallbacks, so .env is optional.

# Admin credentials used for autoLogin and the seeded admin user.
PAYLOAD_ADMIN_EMAIL=dev@payloadcms.com
PAYLOAD_ADMIN_PASSWORD=test

# Payload session secret.
PAYLOAD_SECRET=dev-only-insecure-secret

# SQLite database location.
SQLITE_URL=file:./payload.db

# Origin of the Astro preview app (used for CORS and the collection preview URL).
ASTRO_ORIGIN=http://localhost:4321
