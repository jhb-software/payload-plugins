---
import type { HeadingNode, SlugifyHeadingId, TextNode } from '../types.js'

type Props = {
  node: HeadingNode
  slugifyHeadingId?: SlugifyHeadingId | false
}

const { node, slugifyHeadingId } = Astro.props

const HeadingTag = node.tag

/**
 * Default slugify function for heading IDs.
 * Only generates IDs for h2 and h3 headings.
 */
function defaultSlugifyHeadingId(text: string, tag: string): string | undefined {
  if (!['h2', 'h3'].includes(tag)) {
    return undefined
  }
  return text
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_-]+/g, '-')
    .replace(/^-+|-+$/g, '')
}

const text = (node.children?.[0] as TextNode)?.text
const headingId =
  text && slugifyHeadingId !== false
    ? (slugifyHeadingId ?? defaultSlugifyHeadingId)(text, node.tag)
    : undefined
---

<HeadingTag id={headingId}>
  <slot />
</HeadingTag>
