---
import type { LinkNode, ResolveInternalLink, TextNode } from '../types.js'

type Props = {
  node: LinkNode
  resolveInternalLink?: ResolveInternalLink
}

const { node, resolveInternalLink } = Astro.props

/**
 * Default resolver for internal links.
 * Uses the `path` field from the populated document (works with @jhb.software/payload-pages-plugin).
 */
function defaultResolveInternalLink(doc: Record<string, unknown>): string {
  if ('path' in doc && typeof doc.path === 'string') {
    return doc.path
  }

  throw new Error(
    'Error: Could not resolve internal link. Path field not found in document. Node Text: ' +
      JSON.stringify((node.children?.at(0) as TextNode)?.text ?? node.children),
  )
}

function createLinkElement(node: LinkNode, resolve: ResolveInternalLink) {
  let href: string

  if (node.fields.linkType === 'internal') {
    const doc = node.fields.doc

    if (typeof doc?.value === 'object') {
      href = resolve(doc.value, doc.relationTo) ?? ''
    } else {
      throw new Error(
        'Error: internal Link Node includes unpopulated document value. Node Text: ' +
          JSON.stringify((node.children?.at(0) as TextNode)?.text ?? node.children),
      )
    }
  } else if (node.fields.linkType === 'custom') {
    const url = node.fields.url

    if (!url) {
      throw new Error(
        'Error: custom Link Node includes unpopulated URL. Node Text: ' +
          JSON.stringify((node.children?.at(0) as TextNode)?.text ?? node.children),
      )
    }

    if (url.startsWith('/')) {
      href = url
    } else {
      try {
        new URL(url)

        href = url
      } catch {
        throw new Error(
          'Error: invalid URL. Node Text: ' +
            JSON.stringify((node.children?.at(0) as TextNode)?.text ?? node.children),
        )
      }
    }
  } else {
    throw new Error(
      'Error: invalid link type. Node Text: ' +
        JSON.stringify((node.children?.at(0) as TextNode)?.text ?? node.children),
    )
  }

  const target = node.fields.newTab ? '_blank' : undefined
  const rel = target ? 'noopener' : undefined

  return { href, target, rel, style: (node as unknown as TextNode).style }
}

const linkElement = createLinkElement(node, resolveInternalLink ?? defaultResolveInternalLink)
---

<a
  href={linkElement.href}
  target={linkElement.target}
  rel={linkElement.rel}
  style={linkElement.style}><slot /></a
>
