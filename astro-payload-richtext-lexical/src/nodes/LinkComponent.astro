---
import type { LinkNode, TextNode } from '../types.js'

type Props = {
  node: LinkNode
}

const { node } = Astro.props

function createLinkElement(node: LinkNode) {
  let href = ''

  if (node.fields.linkType === 'internal') {
    const docValue = node.fields.doc?.value

    if (typeof docValue === 'object') {
      // If the pages plugin (https://github.com/jhb-software/payload-plugins/tree/main/pages) is used,
      // the populated doc value will have a path field, use it to build the href:
      if ('path' in docValue && typeof docValue.path === 'string') {
        href = docValue.path
      }
    } else {
      throw new Error(
        'Error: internal Link Node includes unpopulated document value. Node Text: ' +
          JSON.stringify((node.children?.at(0) as TextNode)?.text ?? node.children),
      )
    }
  } else {
    href = sanitizeUrl(node.fields.url ?? '')
  }

  const target = node.fields.newTab ? '_blank' : undefined
  const rel = target ? 'noopener' : undefined

  return { href, target, rel, style: (node as unknown as TextNode).style }
}

const SUPPORTED_URL_PROTOCOLS = new Set(['http:', 'https:', 'mailto:', 'sms:', 'tel:'])
function sanitizeUrl(url: string): string {
  try {
    const parsedUrl = new URL(url)

    if (!SUPPORTED_URL_PROTOCOLS.has(parsedUrl.protocol)) {
      return 'about:blank'
    }
  } catch {
    return url.startsWith('/') ? url : `/${url}`
  }
  return url
}

const linkElement = createLinkElement(node)
---

<a
  href={linkElement.href}
  target={linkElement.target}
  rel={linkElement.rel}
  style={linkElement.style}><slot /></a
>
